/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 0.375rem
  --radius-small 0.1875rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: oklch(0.54 0.16 252) oklch(0.74 0.13 244)
  --accent-ink: oklch(0.34 0.075 258) oklch(0.78 0.052 238)
  --accent-soft: oklch(0.91 0.035 235) oklch(0.25 0.032 246)
  --page-bg: oklch(0.955 0.018 235) oklch(0.16 0.021 252)
  --card-bg: oklch(0.985 0.010 235) oklch(0.22 0.021 250)
  --card-bg-muted: oklch(0.955 0.016 235) oklch(0.19 0.019 250)
  --card-border: oklch(0.82 0.032 235) oklch(0.36 0.030 246)

  --btn-content: oklch(0.42 0.11 252) oklch(0.78 0.10 244)

  --btn-regular-bg: oklch(0.92 0.030 235) oklch(0.29 0.030 248)
  --btn-regular-bg-hover: oklch(0.87 0.046 238) oklch(0.34 0.036 248)
  --btn-regular-bg-active: oklch(0.81 0.060 240) oklch(0.39 0.040 248)

  --btn-plain-bg-hover: oklch(0.92 0.026 235) oklch(0.30 0.027 248)
  --btn-plain-bg-active: oklch(0.87 0.034 238) oklch(0.26 0.024 248)

  --btn-card-bg-hover: oklch(0.945 0.016 235) oklch(0.30 0.026 248)
  --btn-card-bg-active: oklch(0.885 0.028 238) oklch(0.35 0.030 248)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.25 0.025 252)

  --title-active: oklch(0.46 0.13 252)

  --line-divider: oklch(0.78 0.030 235) white(0.10)

  --line-color: oklch(0.76 0.030 235) white(0.12)
  --meta-divider: oklch(0.58 0.04 235) white(0.24)

  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)
  --selection-bg: oklch(0.86 0.060 235) oklch(0.38 0.075 244)
  --codeblock-selection: oklch(0.38 0.075 244)
  --codeblock-bg: oklch(0.20 0.02 252) oklch(0.16 0.018 252)

  --license-block-bg: black(0.03) var(--codeblock-bg)

  --link-underline: oklch(0.82 0.055 235) oklch(0.45 0.07 244)
  --link-hover: oklch(0.90 0.035 235) oklch(0.38 0.065 244)
  --link-active: oklch(0.84 0.055 238) oklch(0.33 0.06 244)

  --float-panel-bg: oklch(0.985 0.012 82) oklch(0.19 0.018 248)

  --scrollbar-bg-light: black(0.4)
  --scrollbar-bg-hover-light: black(0.5)
  --scrollbar-bg-active-light: black(0.6)

  --scrollbar-bg-dark: white(0.4)
  --scrollbar-bg-hover-dark: white(0.5)
  --scrollbar-bg-active-dark: white(0.6)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.7 0.14 180) oklch(0.75 0.14 180)
  --admonitions-color-note: oklch(0.7 0.14 250) oklch(0.75 0.14 250)
  --admonitions-color-important: oklch(0.7 0.14 310) oklch(0.75 0.14 310)
  --admonitions-color-warning: oklch(0.7 0.14 60) oklch(0.75 0.14 60)
  --admonitions-color-caution: oklch(0.6 0.2 25) oklch(0.65 0.2 25)

  --toc-badge-bg: oklch(0.90 0.04 235) var(--btn-regular-bg)
  --toc-btn-hover: oklch(0.91 0.018 235) oklch(0.26 0.022 248)
  --toc-btn-active: oklch(0.86 0.026 238) oklch(0.30 0.024 248)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.54 0.16 252) oklch(0.35 0.07 244)
})
