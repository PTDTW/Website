        {details.length > 0 && (
            <div class="grid gap-3 sm:grid-cols-3">
                {details.map((item) => (
                    <div class="rounded-[var(--radius-small)] border border-[var(--card-border)] bg-[var(--card-bg)] p-4">
                        <div class="text-[0.7rem] uppercase tracking-[0.3em] text-neutral-500 dark:text-neutral-400">{item.label}</div>
                        <div class="mt-2 text-lg font-semibold text-neutral-950 dark:text-white">{item.value}</div>
