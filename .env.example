# Spotify API Configuration
# 
# 獲取這些值的步驟：
# 1. 訪問 https://developer.spotify.com/dashboard
# 2. 登入或註冊 Spotify 開發者帳號
# 3. 建立一個新的應用程式
# 4. 從應用程式設定中獲取 Client ID 和 Client Secret
# 5. 在應用程式設定中設置重定向 URI（例如：http://127.0.0.1:4321/api/spotify/callback/）
# 6. 在 http://127.0.0.1:4321/api/spotify/auth/ 複製授權 URL
# 7. 在瀏覽器中打開該 URL 進行授權
# 8. 複製返回頁面中的 Refresh Token
# 9. 將 Refresh Token 保存到 .env.local

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=https://127.0.0.1:4321/api/spotify/callback/
SPOTIFY_REFRESH_TOKEN=your_refresh_token_here


# https://accounts.spotify.com/authorize?client_id=67fa03a8085d4d7ab14d8f3507e62c29&response_type=code&redirect_uri=http%3A%2F%2Flocalhost%3A3000%2Fapi%2Fspotify%2Fcallback&scope=user-read-currently-playing